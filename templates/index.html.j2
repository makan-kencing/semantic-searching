<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport"
          content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>Semantic Searching - Final Year Papers</title>

    <link rel="stylesheet" href="{{ url_for("static", path="/styles.css") }}">
    <script src="https://cdn.jsdelivr.net/npm/htmx.org@2.0.8/dist/htmx.min.js"></script>
</head>
<body>
<div>
    <form hx-get="/hx-search" hx-target="#search-results" hx-indicator=".htmx-indicator">
        <label for="search">Search:</label>
        <input id="search" name="query" type="search">

        <select name="type" id="type">
            {% for engine in context.available_engines %}
                <option value="{{ engine.__name__ }}">{{ engine.__name__ }}</option>
            {% endfor %}
        </select>

        <button type="submit">Search</button>

        <span class="htmx-indicator">
            <img src="{{ url_for("static", path="img/bars.svg") }}" alt="">
        </span>
    </form>

    <div id="search-results">
    </div>
</div>
</body>
</html>